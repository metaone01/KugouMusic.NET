<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework Condition="'$(TargetFramework)' == '' and $([MSBuild]::IsOSPlatform('Windows'))">net10.0-windows10.0.19041.0</TargetFramework>
        <TargetFramework Condition="'$(TargetFramework)' == '' and !$([MSBuild]::IsOSPlatform('Windows'))">net10.0</TargetFramework>
        <AssemblyName>KugouAvaloniaPlayer</AssemblyName>
        <PackageId>KugouAvaloniaPlayer</PackageId>
        <Nullable>enable</Nullable>
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
        <ApplicationIcon>Assets\Test.ico</ApplicationIcon>

        <Version Condition="'$(BUILD_VERSION)' == ''">1.0.0</Version>
        <Version Condition="'$(BUILD_VERSION)' != ''">$(BUILD_VERSION)</Version>

        <PublishTrimmed>true</PublishTrimmed>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
        <DefineConstants>$(DefineConstants);KUGOU_WINDOWS</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
        <DefineConstants>$(DefineConstants);KUGOU_MACOS</DefineConstants>
    </PropertyGroup>

    <PropertyGroup Condition="!$([MSBuild]::IsOSPlatform('Windows')) and !$([MSBuild]::IsOSPlatform('OSX'))">
        <DefineConstants>$(DefineConstants);KUGOU_LINUX</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <AvaloniaResource Include="Assets\**"/>
        <TrimmerRootAssembly Include="TagLibSharp"/>
        
        <TrimmerRootAssembly Include="Microsoft.EntityFrameworkCore" />
        <TrimmerRootAssembly Include="Microsoft.EntityFrameworkCore.Relational" />
        <TrimmerRootAssembly Include="Microsoft.EntityFrameworkCore.Sqlite" />
        <TrimmerRootAssembly Include="Microsoft.Data.Sqlite" />
        <TrimmerRootAssembly Include="SQLitePCLRaw.core" />
        <TrimmerRootAssembly Include="SQLitePCLRaw.bundle_e_sqlite3" />
        <TrimmerRootAssembly Include="SQLitePCLRaw.provider.e_sqlite3" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="AsyncImageLoader.Avalonia" />
        <PackageReference Include="Avalonia" />
        <PackageReference Include="Avalonia.Controls.ItemsRepeater" />
        <PackageReference Include="Avalonia.Desktop" />
        <PackageReference Include="Avalonia.Themes.Fluent" />
        <PackageReference Include="Avalonia.Fonts.Inter" />
        <!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
        <PackageReference Include="AvaloniaUI.DiagnosticsSupport">
            <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
            <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
        </PackageReference>
        <PackageReference Include="CommunityToolkit.Mvvm"/>
        <PackageReference Include="Jab" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
        <PackageReference Include="Serilog"/>
        <PackageReference Include="Serilog.Extensions.Logging"/>
        <PackageReference Include="Serilog.Sinks.Async" />
        <PackageReference Include="Serilog.Sinks.Console"/>
        <PackageReference Include="Serilog.Sinks.Debug"/>
        <PackageReference Include="Serilog.Sinks.File" />
        <PackageReference Include="SukiUI"/>
        <PackageReference Include="Svg.Controls.Avalonia"/>
        <PackageReference Include="System.Security.Cryptography.ProtectedData"/>
        <PackageReference Include="TagLibSharp"/>
        <PackageReference Include="Tmds.DBus.Protocol"/>
        <PackageReference Include="Velopack" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Libraries\AvaloniaLyrics\AvaloniaLyrics.csproj"/>
        <ProjectReference Include="..\..\Libraries\SimpleAudio\SimpleAudio.csproj"/>
        <ProjectReference Include="..\..\Libraries\KuGou.Net\KuGou.Net.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Compile Update="Views\MyPlaylistsView.axaml.cs">
            <DependentUpon>MyPlaylistsView.axaml</DependentUpon>
            <SubType>Code</SubType>
        </Compile>
        <Compile Update="Views\DailyRecommendView.axaml.cs">
            <DependentUpon>DailyRecommendView.axaml</DependentUpon>
            <SubType>Code</SubType>
        </Compile>
        <Compile Update="Controls\LoginControl.axaml.cs">
            <DependentUpon>LoginControl.axaml</DependentUpon>
        </Compile>
        <Compile Update="Views\UserView.axaml.cs">
            <DependentUpon>UserView.axaml</DependentUpon>
        </Compile>
        <Compile Update="Views\SingerView.axaml.cs">
            <DependentUpon>SingerView.axaml</DependentUpon>
        </Compile>
        <Compile Update="Controls\MediaCard.axaml.cs">
            <DependentUpon>MediaCard.axaml</DependentUpon>
        </Compile>
        <Compile Update="Controls\EqSettingsControl.axaml.cs">
            <DependentUpon>EqSettingsControl.axaml</DependentUpon>
            <SubType>Code</SubType>
        </Compile>
        <Compile Update="Views\DiscoverView.axaml.cs">
            <DependentUpon>DiscoverView.axaml</DependentUpon>
        </Compile>
        <Compile Update="Views\DesktopLyricLockOverlayWindow.axaml.cs">
          <DependentUpon>DesktopLyricLockOverlayWindow.axaml</DependentUpon>
        </Compile>
        <Compile Update="Controls\NowPlaying.MoreFlyout.cs">
          <DependentUpon>NowPlaying.axaml</DependentUpon>
        </Compile>
    </ItemGroup>
</Project>
