<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             x:Class="KugouAvaloniaPlayer.Controls.MediaCard"
             x:Name="Root">

    <Button Name="CardButton"
            Classes="MediaCardButton"
            Width="168" Height="220"
            Margin="8"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding #Root.Command}"
            CommandParameter="{Binding #Root.CommandParameter}"
            ContextMenu="{Binding #Root.ContextMenu}"
            RenderTransformOrigin="0.5,0.5"
            Cursor="Hand">

        <Border CornerRadius="14"
                ClipToBounds="True">

            <Grid RowDefinitions="*, Auto">

                <!-- ── 封面图区域 ── -->
                <Grid Grid.Row="0" Height="168">

                    <!-- 封面图 -->
                    <Border CornerRadius="14,14,14,14" ClipToBounds="True"
                            Background="{StaticResource SukiPrimaryColorLow}">
                        <Image asyncImageLoader:ImageLoader.Source="{Binding #Root.Cover}"
                                             behaviors:ImageRenderOptions.InterpolationSource="{Binding #Root.Cover}"
                                             Width="168"
                                             Height="168"
                                             Stretch="UniformToFill"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                    </Border>

                    <!-- 角标/额外内容 -->
                    <ContentPresenter Content="{Binding #Root.OverlayContent}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,8,8,0" />
                </Grid>

                <!-- ── 信息区域 ── -->
                <Border Grid.Row="1"
                        Padding="12,10,12,12"
                        Background="{StaticResource SukiPrimaryColor0}">
                    <StackPanel Spacing="3">
                        <TextBlock Text="{Binding #Root.Title}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="144" />
                        <TextBlock Text="{Binding #Root.Subtitle}"
                                   FontSize="11"
                                   Opacity="0.55"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="144"
                                   IsVisible="{Binding #Root.HasSubtitle}" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Button>
</UserControl>
