<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:lyrics="clr-namespace:AvaloniaLyrics;assembly=AvaloniaLyrics"
             xmlns:controls1="clr-namespace:KugouAvaloniaPlayer.Controls"
             x:Class="KugouAvaloniaPlayer.Controls.NowPlaying"
             x:DataType="vm:NowPlayingViewModel">

    <UserControl.Styles>
        <Style Selector="Grid#Root">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(200px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid#Root.open">
            <Setter Property="IsHitTestVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,15" /> <!-- 增加行间距 -->
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Grid.VisualizerBarItem">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.VisualizerBarGlow">
            <Setter Property="Width" Value="12" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Opacity" Value="0.24" />
            <Setter Property="Background" Value="#26FFFFFF" />
            <Setter Property="BoxShadow" Value="0 0 18 3 #3DFFFFFF" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.08" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.VisualizerBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                    <GradientStop Color="#08FFFFFF" Offset="0.0" />
                    <GradientStop Color="#54FFFFFF" Offset="0.34" />
                    <GradientStop Color="#D8FFFFFF" Offset="0.72" />
                    <GradientStop Color="#A8F8FFFF" Offset="1.0" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BoxShadow" Value="0 0 10 1 #66FFFFFF" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.08" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.VisualizerBarHighlight">
            <Setter Property="Width" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Opacity" Value="0.42" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#FFFFFFFF" Offset="0.0" />
                    <GradientStop Color="#66FFFFFF" Offset="0.42" />
                    <GradientStop Color="#00FFFFFF" Offset="1.0" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.08" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="StackPanel#AlbumMotionContainer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.PortraitModeButton">
            <Setter Property="Background" Value="#30FFFFFF" />
        </Style>
        <Style Selector="Border.PortraitModeButton.active">
            <Setter Property="Background" Value="#5AFFFFFF" />
        </Style>

        <Style Selector="Image.NowPlayingBackgroundLayer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.7" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

    </UserControl.Styles>

    <Grid Name="Root"
          Classes.open="{Binding IsOpen}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          ClipToBounds="True">
        <Panel>
            <Image asyncImageLoader:ImageLoader.Source="{Binding Player.PreparedNextCover}"
                                 Width="1"
                                 Height="1"
                                 Opacity="0"
                                 IsHitTestVisible="False"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top" />
            <Border Background="#FF000000" />
            <Image asyncImageLoader:ImageLoader.Source="{Binding Player.DisplayedPlayingSong.Cover}"
                                 Stretch="UniformToFill"
                                 RenderTransformOrigin="0.5,0.5"
                                 RenderTransform="scale(1.12)"
                                 Opacity="{Binding CoverBackgroundOpacity}"
                                 Classes="NowPlayingBackgroundLayer">
                <Image.Effect>
                    <BlurEffect Radius="40" />
                </Image.Effect>
            </Image>
            <Image asyncImageLoader:ImageLoader.Source="{Binding PortraitBackgroundA}"
                   Stretch="UniformToFill"
                   RenderTransformOrigin="0.5,0.5"
                   RenderTransform="scale(1.04)"
                   Opacity="{Binding PortraitLayerAOpacity}"
                   Classes="NowPlayingBackgroundLayer" />
            <Image asyncImageLoader:ImageLoader.Source="{Binding PortraitBackgroundB}"
                   Stretch="UniformToFill"
                   RenderTransformOrigin="0.5,0.5"
                   RenderTransform="scale(1.04)"
                   Opacity="{Binding PortraitLayerBOpacity}"
                   Classes="NowPlayingBackgroundLayer" />

            <Grid IsHitTestVisible="False"
                  IsVisible="{Binding Player.IsNowPlayingVisualizerEnabled}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  RowDefinitions="*,Auto"
                  Opacity="0.68"
                  ZIndex="2">

                <!-- Ambient bottom glow -->
                <Border Grid.Row="1"
                        Height="170"
                        Margin="-80,0,-80,-30"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        IsHitTestVisible="False"
                        Opacity="0.2">
                    <Border.Background>
                        <RadialGradientBrush Center="50%,100%" GradientOrigin="50%,100%" RadiusX="0.82" RadiusY="0.72">
                            <GradientStop Color="#00FFFFFF" Offset="0.0" />
                            <GradientStop Color="#22FFFFFF" Offset="0.35" />
                            <GradientStop Color="#42FFFFFF" Offset="0.66" />
                            <GradientStop Color="#00FFFFFF" Offset="1.0" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <Border Grid.Row="1"
                        Height="1"
                        Margin="-40,0,-40,28"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Opacity="0.18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#00FFFFFF" Offset="0.0" />
                            <GradientStop Color="#C8FFFFFF" Offset="0.5" />
                            <GradientStop Color="#00FFFFFF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Main visualizer bars -->
                <ItemsControl Grid.Row="1"
                              Height="235"
                              Margin="-20,0,-20,-24"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              ItemsSource="{Binding Player.NowPlayingVisualizerBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AudioVisualizerBarViewModel">
                            <Grid Classes="VisualizerBarItem"
                                  Opacity="{Binding Opacity}">
                                <Border Classes="VisualizerBarGlow"
                                        Height="{Binding Height}" />
                                <Border Classes="VisualizerBar"
                                        Height="{Binding Height}" />
                                <Border Classes="VisualizerBarHighlight"
                                        Height="{Binding Height}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Border Background="#50000000" />
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#24000000" Offset="0" />
                        <GradientStop Color="#64000000" Offset="0.48" />
                        <GradientStop Color="#90000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Panel>
        <Grid RowDefinitions="Auto, *" Margin="40">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0">
                <Button Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        Classes="Basic">
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="15,8">
                        <PathIcon Data="{x:Static suki:Icons.ChevronDown}" Foreground="White" Width="15" Height="15" />
                    </Border>
                </Button>

                <Button Cursor="Hand"
                        Command="{Binding ToggleLyricDisplayModeCommand}"
                        Classes="Basic"
                        ToolTip.Tip="歌词显示模式">
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Svg Path="/Assets/translation-svgrepo-com.svg"
                                 Css="path { fill: white; }"
                                 Width="25"                                                                                                                                                                                 
                                 Height="25"
                                 Opacity="0.9" />
                        </StackPanel>
                    </Border>
                </Button>

                <Button Cursor="Hand"
                        Command="{Binding TogglePortraitModeCommand}"
                        Classes="Basic"
                        ToolTip.Tip="写真模式"
                        IsVisible="{Binding IsPortraitAvailable}">
                    <Border Classes="PortraitModeButton"
                            Classes.active="{Binding IsPortraitModeEnabled}"
                            CornerRadius="20"
                            Padding="12,8">
                        <Svg Path="/Assets/portrait-mode.svg"
                             Css="path { stroke: white; fill: none; } circle { stroke: white; fill: none; }"
                             Width="25"
                             Height="25"
                             Opacity="0.9" />
                    </Border>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="4*, 6*" Margin="0,30,0,28">

                <StackPanel Grid.Column="0"
                            x:Name="AlbumMotionContainer"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="40"
                            IsVisible="{Binding IsStandardLayoutVisible}"
                            Opacity="{Binding Player.NowPlayingArtworkOpacity}">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="{Binding Player.NowPlayingArtworkTranslateY}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Y" Duration="0:0:0.28" Easing="CubicEaseOut" />
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </StackPanel.RenderTransform>
                    <suki:GlassCard CornerRadius="20" Padding="0" Width="320" Height="320" MinWidth="220"
                                    MinHeight="220" MaxWidth="350" MaxHeight="350">
                        <Image asyncImageLoader:ImageLoader.Source="{Binding Player.DisplayedPlayingSong.Cover}" Stretch="UniformToFill" />
                    </suki:GlassCard>

                    <StackPanel Spacing="10" HorizontalAlignment="Left" Margin="10,0">
                        <TextBlock Text="{Binding Player.DisplayedPlayingSong.Name}"
                                   FontSize="28" FontWeight="ExtraLight" Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Player.DisplayedPlayingSong.Singer}"
                                   FontSize="18" Foreground="#DDFFFFFF"
                                   TextTrimming="CharacterEllipsis" />
                        <Grid RowDefinitions="Auto, Auto, Auto" VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Center">
                                <Button Cursor="Hand"
                                        Command="{Binding ToggleVolumeCommand}"
                                        Classes="Basic">
                                    <Svg Path="/Assets/VolumeUp.svg"
                                         Css="path { fill: white; }"
                                         Width="20"
                                         Height="20"
                                         Opacity="0.85" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayPreviousCommand}" Classes="Basic"
                                        ToolTip.Tip="上一首">
                                    <Svg Path="/Assets/backward.svg" Css="path { fill: white; }" Width="18" Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic"
                                        Width="36"
                                        Height="36">
                                    <Panel>
                                        <Svg Path="/Assets/pause-1006-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding Player.IsPlayingAudio}" />
                                        <Svg Path="/Assets/play-1003-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding !Player.IsPlayingAudio}" />
                                    </Panel>
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayNextCommand}" Classes="Basic"
                                        ToolTip.Tip="下一首">
                                    <Svg Path="/Assets/next-svgrepo-com.svg" Css="path { fill: white; }" Width="18"
                                         Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.ToggleLikeCommand}"
                                        Classes="Basic"
                                        ToolTip.Tip="添加到我喜欢">
                                    <Panel>
                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: red; }"
                                             Width="20" Height="20"
                                             IsVisible="{Binding Player.IsLiked}" />

                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: white; }"
                                             Opacity="0.6"
                                             Width="20" Height="20"
                                             IsVisible="{Binding !Player.IsLiked}" />
                                    </Panel>
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  MinWidth="220"
                                  MaxWidth="420"
                                  Margin="0,4,0,0"
                                  HorizontalAlignment="Stretch">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Slider Grid.Column="1" Minimum="0" Maximum="{Binding Player.TotalDurationSeconds}"
                                            Value="{Binding Player.CurrentPositionSeconds}"
                                            Margin="8,0" IsSnapToTickEnabled="False"
                                            HorizontalAlignment="Stretch"
                                            Classes="Player PlayerDark" />
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="Auto, *, Auto"
                                  MinWidth="220"
                                  MaxWidth="420"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Center"
                                  IsVisible="{Binding IsVolumeVisible}">
                                <Svg Path="/Assets/VolumeOff.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.78"
                                     VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding Player.MusicVolume}"
                                        Margin="10,0"
                                        Classes="Player PlayerLight PlayerCompact"
                                        HorizontalAlignment="Stretch" />
                                <Svg Grid.Column="2"
                                     Path="/Assets/VolumeUp.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.9"
                                     VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <lyrics:LyricView x:Name="LyricScrollView"
                                  Grid.Column="{Binding LyricsGridColumn}"
                                  Grid.ColumnSpan="{Binding LyricsGridColumnSpan}"
                                  Lines="{Binding Player.RenderLyricLines}"
                                  Position="{Binding Player.CurrentPosition}"
                                  IsActive="{Binding IsOpen}"
                                  Preset="AppleMusicClassic"
                                  Margin="{Binding LyricsMargin}"
                                  ShowTranslation="{Binding IsTranslationVisible}"
                                  ShowRomanization="{Binding IsRomanizationVisible}"
                                  FontFamily="{Binding LyricFontFamily}"
                                  TextAlignment="{Binding LyricTextAlignment}"
                                  PrimaryFontSize="{Binding LyricFontSize}"
                                  TranslationFontSize="{Binding TranslationFontSize}"
                                  RomanizationFontSize="{Binding TranslationFontSize}"
                                  PrimaryForeground="{Binding LyricForeground}"
                                  PrimaryPlayedForeground="{Binding LyricForeground}"
                                  TranslationForeground="{Binding TranslationLineForeground}"
                                  TranslationPlayedForeground="{Binding TranslationWordForeground}"
                                  RomanizationForeground="{Binding TranslationLineForeground}"
                                  Opacity="{Binding Player.NowPlayingLyricsOpacity}">
                    <lyrics:LyricView.RenderTransform>
                        <TranslateTransform Y="{Binding Player.NowPlayingLyricsTranslateY}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Y" Duration="0:0:0.32" Easing="CubicEaseOut" />
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </lyrics:LyricView.RenderTransform>
                </lyrics:LyricView>

                <TextBlock Grid.Column="{Binding LyricsGridColumn}"
                           Grid.ColumnSpan="{Binding LyricsGridColumnSpan}"
                           Text="暂无歌词"
                           IsVisible="{Binding !Player.LyricLines.Count}"
                           Foreground="White" Opacity="0.5" FontSize="24" FontWeight="ExtraLight"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

        </Grid>
    </Grid>
</UserControl>
