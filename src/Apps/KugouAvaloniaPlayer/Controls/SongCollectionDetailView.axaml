<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             x:Class="KugouAvaloniaPlayer.Controls.SongCollectionDetailView"
             x:Name="Root">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="CollectionHeroOverlayTop">#100B1D42</Color>
                    <Color x:Key="CollectionHeroOverlayMid">#180B1D42</Color>
                    <Color x:Key="CollectionHeroOverlayBottom">#300B1D42</Color>
                    <Color x:Key="CollectionHeroFadeStart">#00FFFFFF</Color>
                    <Color x:Key="CollectionHeroFadeMid">#28FFFFFF</Color>
                    <Color x:Key="CollectionHeroFadeEnd">#F6FFFFFF</Color>
                    <SolidColorBrush x:Key="CollectionTableHeadingBrush" Color="#6D78A0" />
                    <SolidColorBrush x:Key="CollectionCoverBorderBrush" Color="#70FFFFFF" />
                    <SolidColorBrush x:Key="CollectionCoverBackgroundBrush" Color="#28FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroIconButtonBrush" Color="#2AFFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroIconButtonHoverBrush" Color="#40FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroButtonBorderBrush" Color="#58FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroActionBrush" Color="#24FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroActionHoverBrush" Color="#38FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroActionBorderBrush" Color="#50FFFFFF" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="CollectionHeroOverlayTop">#24101B35</Color>
                    <Color x:Key="CollectionHeroOverlayMid">#34101B35</Color>
                    <Color x:Key="CollectionHeroOverlayBottom">#68101B35</Color>
                    <Color x:Key="CollectionHeroFadeStart">#0012192A</Color>
                    <Color x:Key="CollectionHeroFadeMid">#A012192A</Color>
                    <Color x:Key="CollectionHeroFadeEnd">#FF12192A</Color>
                    <SolidColorBrush x:Key="CollectionTableHeadingBrush" Color="#9CA8C6" />
                    <SolidColorBrush x:Key="CollectionCoverBorderBrush" Color="#66FFFFFF" />
                    <SolidColorBrush x:Key="CollectionCoverBackgroundBrush" Color="#242A3550" />
                    <SolidColorBrush x:Key="CollectionHeroIconButtonBrush" Color="#30000000" />
                    <SolidColorBrush x:Key="CollectionHeroIconButtonHoverBrush" Color="#4A000000" />
                    <SolidColorBrush x:Key="CollectionHeroButtonBorderBrush" Color="#34FFFFFF" />
                    <SolidColorBrush x:Key="CollectionHeroActionBrush" Color="#2A000000" />
                    <SolidColorBrush x:Key="CollectionHeroActionHoverBrush" Color="#44000000" />
                    <SolidColorBrush x:Key="CollectionHeroActionBorderBrush" Color="#30FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.HeroIconButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="Background" Value="{DynamicResource CollectionHeroIconButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CollectionHeroButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.HeroIconButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource CollectionHeroIconButtonHoverBrush}" />
        </Style>
        <Style Selector="Button.HeroPrimaryButton">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.HeroPrimaryButton:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.HeroActionButton">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="Background" Value="{DynamicResource CollectionHeroActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CollectionHeroActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.HeroActionButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource CollectionHeroActionHoverBrush}" />
        </Style>
        <Style Selector="Button.HeroActionButton TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.HeroActionButton PathIcon">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="TextBlock.TableHeading">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource CollectionTableHeadingBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Margin="{Binding #Root.HeaderMargin}">
        <Grid Grid.Row="0"
              Height="188"
              ClipToBounds="False">
            <Border CornerRadius="22,22,0,0"
                    ClipToBounds="True"
                    Background="{DynamicResource SukiPrimaryColorLow}">
                <Grid>
                    <Image asyncImageLoader:ImageLoader.Source="{Binding #Root.CurrentHeroBackground}"
                           IsVisible="{DynamicResource KugouHeroBackgroundImageVisible}"
                           Stretch="UniformToFill" />
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="{DynamicResource CollectionHeroOverlayTop}" Offset="0" />
                                <GradientStop Color="{DynamicResource CollectionHeroOverlayMid}" Offset="0.62" />
                                <GradientStop Color="{DynamicResource CollectionHeroOverlayBottom}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border IsVisible="{DynamicResource KugouHeroBackgroundImageVisible}"
                            VerticalAlignment="Bottom"
                            Height="76">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="{DynamicResource CollectionHeroFadeStart}" Offset="0" />
                                <GradientStop Color="{DynamicResource CollectionHeroFadeMid}" Offset="0.56" />
                                <GradientStop Color="{DynamicResource CollectionHeroFadeEnd}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="Auto,*"
                  Margin="28,20,28,18">
                <Border Grid.Column="0"
                        Width="164"
                        Height="164"
                        IsVisible="{Binding #Root.ShowCover}"
                        CornerRadius="16"
                        ClipToBounds="True"
                        VerticalAlignment="Top"
                        BorderBrush="{DynamicResource CollectionCoverBorderBrush}"
                        BorderThickness="2"
                        Background="{DynamicResource CollectionCoverBackgroundBrush}">
                    <Image asyncImageLoader:ImageLoader.Source="{Binding #Root.Cover}" Stretch="UniformToFill" />
                </Border>

                <Grid Grid.Column="1"
                      Margin="24,0,0,0">
                    <StackPanel Margin="0,6,54,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Spacing="10">
                        <TextBlock Text="{Binding #Root.Title}"
                                   FontSize="{Binding #Root.TitleFontSize}"
                                   FontWeight="ExtraBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="{Binding #Root.TitleMaxWidth}" />
                        <TextBlock Text="{Binding #Root.Subtitle}"
                                   IsVisible="{Binding #Root.HasSubtitle}"
                                   FontSize="14"
                                   Foreground="#DCE5FF"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="{Binding #Root.TitleMaxWidth}" />

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12"
                              HorizontalAlignment="Left"
                              MaxWidth="{Binding #Root.TitleMaxWidth}">
                            <Button Classes="HeroPrimaryButton"
                                    Command="{Binding #Root.PlayFirstSongCommand}"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Svg Classes="ThemeSvgIcon" Path="/Assets/play-1003-svgrepo-com.svg" Width="16" Height="16" />
                                    <TextBlock Text="播放全部" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Classes="HeroActionButton"
                                    Command="{Binding #Root.HeroActionCommand}"
                                    IsVisible="{Binding #Root.HasHeroAction}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Svg Classes="ThemeSvgIcon"
                                         Path="{Binding #Root.HeroActionSvgPath}"
                                         Width="16"
                                         Height="16"
                                         IsVisible="{Binding #Root.HasHeroActionSvgPath}" />
                                    <PathIcon Data="{Binding #Root.HeroActionIconData}"
                                              Width="16"
                                              Height="16"
                                              IsVisible="{Binding #Root.HasHeroActionIconData}" />
                                    <TextBlock Text="{Binding #Root.HeroActionText}"
                                               IsVisible="{Binding #Root.HasHeroActionText}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Button Command="{Binding #Root.BackCommand}"
                            Classes="Basic HeroIconButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Cursor="Hand"
                            ToolTip.Tip="返回">
                        <PathIcon Data="{x:Static suki:Icons.ChevronLeft}"
                                  Foreground="White"
                                  Width="22"
                                  Height="22" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <suki:GlassCard Grid.Row="1"
                        Classes="CollectionPanel"
                        Margin="{Binding #Root.ListMargin}"
                        Padding="22,16,22,0"
                        CornerRadius="18">
            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,150,80,150"
                      Margin="70,0,16,8">
                    <TextBlock Classes="TableHeading" Text="歌曲" />
                    <TextBlock Grid.Column="1" Classes="TableHeading" Text="专辑" />
                    <TextBlock Grid.Column="2" Classes="TableHeading" Text="时长" />
                    <TextBlock Grid.Column="3" Classes="TableHeading" Text="操作" HorizontalAlignment="Right" Margin="0,0,50,0"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ListBox Classes="SongList"
                             ItemsSource="{Binding #Root.Songs}"
                             behaviors:InteractionBehaviors.ScrollNearBottomCommand="{Binding #Root.LoadMoreCommand}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="{Binding #Root.ListPadding}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:SongItem">
                                <localControls:SongListItemControl />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding #Root.IsLoading}"
                                Spacing="10">
                        <suki:Loading Width="40" Height="40" />
                        <TextBlock Text="{Binding #Root.LoadingText}"
                                   Foreground="{DynamicResource SukiLiquid2}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="10"
                                Spacing="10"
                                IsVisible="{Binding #Root.IsLoadingMore}">
                        <suki:Loading Width="20" Height="20" />
                        <TextBlock Text="{Binding #Root.LoadingMoreText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SukiLiquid2}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </suki:GlassCard>
    </Grid>
</UserControl>
