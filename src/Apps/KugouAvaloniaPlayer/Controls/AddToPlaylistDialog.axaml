<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="KugouAvaloniaPlayer.Controls.AddToPlaylistDialog"
             x:Name="DialogRoot"
             x:DataType="vm:AddToPlaylistDialogViewModel">

    <UserControl.Styles>
        <Style Selector="Button.PlaylistCard">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.PlaylistCard Border.Chrome">
            <Setter Property="Background" Value="{DynamicResource SukiPrimaryColorLow}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SukiBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.PlaylistCard:pointerover Border.Chrome">
            <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor1}" />
        </Style>

        <Style Selector="ListBox.PlaylistPickerList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.IsScrollChainingEnabled" Value="False" />
        </Style>

        <Style Selector="ListBox.PlaylistPickerList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="Transparent" />
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Border Width="760"
            Padding="22"
            Background="{DynamicResource SukiBackground}"
            CornerRadius="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Grid ColumnDefinitions="Auto,*"
                  Margin="0,0,0,18">
                <Border Width="72"
                        Height="72"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <Image asyncImageLoader:ImageLoader.Source="{Binding SongCover}"
                                         Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock Text="添加到歌单"
                               FontSize="24"
                               FontWeight="ExtraBold" />
                    <TextBlock Text="{Binding SongName}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding SongSinger}"
                               Foreground="{DynamicResource SukiLowText}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>

            <Grid Row="1"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,16">
                <TextBox PlaceholderText="搜索歌单"
                         Text="{Binding FilterText}"
                         Width="320" />

                <Border Grid.Column="1"
                        Padding="12,8"
                        CornerRadius="999"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <TextBlock Text="{Binding FilteredPlaylists.Count, StringFormat='共 {0} 个可选歌单'}"
                               Foreground="{DynamicResource SukiLowText}" />
                </Border>
            </Grid>

            <Grid Row="2">
                <Border IsVisible="{Binding !HasFilteredPlaylists}"
                        Padding="24"
                        CornerRadius="16"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="没有找到匹配的歌单"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="换个关键词试试，或者先新建一个歌单。"
                                   Foreground="{DynamicResource SukiLowText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Grid IsVisible="{Binding HasFilteredPlaylists}">
                    <ListBox Classes="PlaylistPickerList"
                             MaxHeight="360"
                             SelectionMode="Single"
                             ItemsSource="{Binding FilteredPlaylists}"
                             behaviors:InteractionBehaviors.ScrollNearBottomCommand="{Binding LoadMorePlaylistsCommand}"
                             behaviors:InteractionBehaviors.ScrollNearBottomThreshold="120">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PlaylistDialogPlaylistItemViewModel">
                                <Button Classes="PlaylistCard"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="102"
                                        Command="{Binding #DialogRoot.((vm:AddToPlaylistDialogViewModel)DataContext).SelectPlaylistCommand}"
                                        CommandParameter="{Binding .}">
                                    <Grid>
                                        <Border Classes="Chrome"
                                                CornerRadius="18" />

                                        <Border CornerRadius="18"
                                                BorderBrush="{StaticResource SukiPrimaryColor}"
                                                BorderThickness="2"
                                                IsVisible="{Binding IsSelected}" />

                                        <Grid ColumnDefinitions="76,*"
                                              Margin="10">
                                            <Border Width="66"
                                                    Height="66"
                                                    CornerRadius="14"
                                                    ClipToBounds="True"
                                                    Background="{StaticResource SukiPrimaryColor0}"
                                                    VerticalAlignment="Center">
                                                <Image asyncImageLoader:ImageLoader.Source="{Binding Cover}"
                                                                     Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Margin="12,2,8,2"
                                                        VerticalAlignment="Center"
                                                        Spacing="5">
                                                <Border Padding="8,3"
                                                        CornerRadius="999"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource SukiPrimaryColor0}">
                                                    <TextBlock Text="{Binding BadgeText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SukiPrimaryColor}" />
                                                </Border>

                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="112" />

                                                <TextBlock Text="{Binding Subtitle}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource SukiLowText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="112" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Padding="12,8"
                            CornerRadius="999"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource SukiBackground}"
                            IsVisible="{Binding IsLoadingMorePlaylists}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <suki:Loading Width="14"
                                          Height="14" />
                            <TextBlock Text="正在加载更多歌单..."
                                       Foreground="{DynamicResource SukiLowText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Row="3"
                  ColumnDefinitions="*,Auto,Auto"
                  Margin="0,18,0,0">
                <TextBlock Text="{Binding SelectedPlaylist.Name, StringFormat='已选择：{0}', FallbackValue='已选择：'}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SukiLowText}" />

                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Classes="Basic"
                        Margin="0,0,10,0">
                    <TextBlock Text="取消" />
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding ConfirmCommand}"
                        Classes="Standard"
                        IsEnabled="{Binding CanConfirm}"
                        MinWidth="132">
                    <Grid ColumnDefinitions="Auto,Auto">
                        <suki:Loading Width="16"
                                      Height="16"
                                      Margin="0,0,8,0"
                                      IsVisible="{Binding IsSubmitting}" />
                        <TextBlock Grid.Column="1"
                                   Text="正在添加..."
                                   IsVisible="{Binding IsSubmitting}" />
                        <TextBlock Grid.Column="1"
                                   Text="添加到所选歌单"
                                   IsVisible="{Binding !IsSubmitting}" />
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
