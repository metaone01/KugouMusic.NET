<localControls:KugouWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="https://github.com/kikipoulet/SukiUI"
                 xmlns:chrome="clr-namespace:Avalonia.Controls.Chrome;assembly=Avalonia.Controls"
                 xmlns:views="clr-namespace:KugouAvaloniaPlayer.Views"
                 xmlns:localControls="clr-namespace:KugouAvaloniaPlayer.Controls"
                 mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
                 x:Class="KugouAvaloniaPlayer.Views.MainWindow"
                 MinHeight="600"
                 MinWidth="800"
                 x:DataType="vm:MainWindowViewModel"
                 Name="RootWindow"
                 Icon="/Assets/Test.ico"
                 Title="KA Music"
                 Background="Transparent"
                 CanMaximize="True"
                 TransparencyLevelHint="Transparent">

    <localControls:KugouWindow.Styles>
        <Style Selector="Button.SidebarPlaylistOption">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource SukiLowText}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Border Name="OptionBackground"
                                Background="{DynamicResource SukiPrimaryColorLow}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <Border Name="OptionAccent"
                                Width="3"
                                Margin="0,8,0,8"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource SukiPrimaryColor}"
                                CornerRadius="2"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pointerover /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pressed /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.75" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected">
            <Setter Property="Foreground" Value="{DynamicResource SukiPrimaryColor}" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected /template/ Border#OptionAccent">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ListBox.SidebarPlaylistList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.IsScrollChainingEnabled" Value="False" />
        </Style>
        <Style Selector="ListBox.SidebarPlaylistList ListBoxItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="Transparent" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ListBox.SidebarPlaylistList ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox.SidebarPlaylistList ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ToggleButton.SidebarSectionHeader">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="4,0,8,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource SukiLowText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Border Name="HeaderBackground"
                                Background="{DynamicResource SukiPrimaryColorLow}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.14" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <Grid ColumnDefinitions="20,*"
                              Margin="{TemplateBinding Padding}">
                            <Svg Name="SectionChevron"
                                 Classes="ThemeSvgIcon"
                                 Path="/Assets/NavigateNext.svg"
                                 Width="14"
                                 Height="14"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="50%,50%">
                                <Svg.Transitions>
                                    <Transitions>
                                        <TransformOperationsTransition Property="RenderTransform"
                                                                       Duration="0:0:0.14"
                                                                       Easing="CubicEaseOut" />
                                    </Transitions>
                                </Svg.Transitions>
                            </Svg>
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.SidebarSectionHeader:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
        </Style>
        <Style Selector="ToggleButton.SidebarSectionHeader:pointerover /template/ Border#HeaderBackground">
            <Setter Property="Opacity" Value="0.42" />
        </Style>
        <Style Selector="ToggleButton.SidebarSectionHeader:pressed /template/ Border#HeaderBackground">
            <Setter Property="Opacity" Value="0.62" />
        </Style>
        <Style Selector="ToggleButton.SidebarSectionHeader:checked /template/ Svg#SectionChevron">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>
        <Style Selector="suki|SukiSideMenuItem /template/ TextBlock#PART_Header">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="suki|SukiSideMenuItem[IsSelected=True] /template/ TextBlock#PART_Header">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="localControls|KugouWindow[WindowState=Maximized] PathIcon#MaximizeIcon">
            <Setter Property="Data" Value="{x:Static suki:Icons.WindowRestore}" />
        </Style>
        <Style Selector="localControls|KugouWindow[WindowState=FullScreen] Button#MaximizeButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="localControls|KugouWindow[WindowState=FullScreen] PathIcon#FullScreenIcon">
            <Setter Property="Data" Value="{x:Static suki:Icons.WindowFullScreenOff}" />
        </Style>
        <Style Selector="localControls|KugouWindow[WindowState=Maximized] suki|SukiMainHost#WindowHost">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="localControls|KugouWindow[WindowState=FullScreen] suki|SukiMainHost#WindowHost">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </localControls:KugouWindow.Styles>

    <suki:SukiMainHost Name="WindowHost"
                       BackgroundStyle="Bubble"
                       CornerRadius="10">
        <suki:SukiMainHost.Hosts>
            <suki:SukiToastHost Manager="{Binding ToastManager}" />
            <suki:SukiDialogHost Manager="{Binding DialogManager}" />
        </suki:SukiMainHost.Hosts>

    <Grid Name="MainGrid">
        <Grid Name="TitleBar"
              ColumnDefinitions="48,*,Auto"
              Height="36"
              Background="Transparent"
              VerticalAlignment="Top"
              IsVisible="{Binding !NowPlaying.IsOpen}"
              ZIndex="20"
              chrome:WindowDecorationProperties.ElementRole="TitleBar">
            <Border Grid.Column="1"
                    Background="Transparent"
                    chrome:WindowDecorationProperties.ElementRole="TitleBar" />

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="7"
                        Margin="0,12,12,0"
                        VerticalAlignment="Center"
                        chrome:WindowDecorationProperties.ElementRole="User">
                
                <TextBox Text="{Binding SearchKeyword}"
                         PlaceholderText="输入歌曲、歌手、歌单或专辑..."
                         CornerRadius="15"
                         Height="34"
                         Width="260"
                         FontSize="12"
                         VerticalContentAlignment="Center">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                    <TextBox.InnerLeftContent>
                        <PathIcon Data="{x:Static suki:Icons.Search}"
                                  Width="12"
                                  Height="12"
                                  Foreground="{DynamicResource SukiLowText}" />
                    </TextBox.InnerLeftContent>
                </TextBox>
                <Button Classes="WindowControlsButton"
                        Command="{Binding NavigateToUserCommand}"
                        ToolTip.Tip="设置"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <Svg Classes="ThemeSvgIcon"
                         Path="/Assets/gear-svgrepo-com.svg"
                         Width="18"
                         Height="18"
                         VerticalAlignment="Center" />
                </Button>
                <Button Classes="WindowControlsButton"
                        Command="{Binding RequestWindowToggleFullScreenCommand}"
                        ToolTip.Tip="全屏"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <PathIcon Name="FullScreenIcon"
                              Data="{x:Static suki:Icons.WindowFullScreen}"
                              Width="12"
                              Height="12" />
                </Button>
                <Button Classes="WindowControlsButton"
                        Command="{Binding RequestWindowMinimizeCommand}"
                        ToolTip.Tip="最小化"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <PathIcon Data="{x:Static suki:Icons.WindowMinimize}"
                              Width="12"
                              Height="12"
                              Margin="0,0,0,-6.5" />
                </Button>
                <Button Name="MaximizeButton"
                        Classes="WindowControlsButton"
                        Command="{Binding RequestWindowToggleMaximizeCommand}"
                        ToolTip.Tip="最大化/还原"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <PathIcon Name="MaximizeIcon"
                              Data="{x:Static suki:Icons.WindowMaximize}"
                              Width="12"
                              Height="12" />
                </Button>
                <Button Classes="WindowControlsButton Close"
                        Command="{Binding RequestWindowCloseCommand}"
                        ToolTip.Tip="关闭"
                        chrome:WindowDecorationProperties.ElementRole="User">
                    <PathIcon Data="{x:Static suki:Icons.WindowClose}"
                              Width="12"
                              Height="12" />
                </Button>
            </StackPanel>
        </Grid>

        <localControls:KugouSideMenu
            ItemsSource="{Binding Pages}"
            SelectedItem="{Binding SelectedMenuPage}"
            UseCustomContent="True"
            Content="{Binding ActivePage}"
            IsSearchEnabled="False">

            <localControls:KugouSideMenu.HeaderContent>
                <Border Margin="16,10,16,14"
                        Padding="8"
                        CornerRadius="10"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <localControls:UserAvatarControl />
                </Border>
            </localControls:KugouSideMenu.HeaderContent>

            <localControls:KugouSideMenu.ItemTemplate>
                <DataTemplate DataType="vm:PageViewModelBase">
                    <suki:SukiSideMenuItem Header="{Binding DisplayName}" FontWeight="Bold">
                        <suki:SukiSideMenuItem.Icon>
                            <Svg Classes="ThemeSvgIcon" Path="{Binding Icon}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </suki:SukiSideMenuItem.Icon>
                    </suki:SukiSideMenuItem>
                </DataTemplate>
            </localControls:KugouSideMenu.ItemTemplate>

            <localControls:KugouSideMenu.FooterContent>
                <StackPanel Margin="10,4,10,100" Spacing="10">
                    <Separator Margin="0,4,0,2" />

                    <StackPanel Spacing="6"
                                MaxHeight="430">
                        <ToggleButton Name="CreatedPlaylistsHeader"
                                      Classes="SidebarSectionHeader"
                                      Content="创建的歌单"
                                      IsChecked="{Binding IsCreatedPlaylistsExpanded, Mode=TwoWay}" />
                        <StackPanel Spacing="8"
                                    IsVisible="{Binding IsCreatedPlaylistsExpanded}">
                                    <ListBox Classes="SidebarPlaylistList"
                                             MaxHeight="320"
                                             SelectionMode="Single"
                                             ItemsSource="{Binding SidebarCreatedPlaylists}">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <localControls:SidebarPlaylistItemControl
                                                    OpenCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                    DeleteOnlinePlaylistCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteOnlinePlaylistCommand}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                        </StackPanel>

                        <ToggleButton Name="CollectedPlaylistsHeader"
                                      Classes="SidebarSectionHeader"
                                      Content="收藏的歌单"
                                      IsChecked="{Binding IsCollectedPlaylistsExpanded, Mode=TwoWay}" />
                        <StackPanel Spacing="8"
                                    IsVisible="{Binding IsCollectedPlaylistsExpanded}">
                                    <ListBox Classes="SidebarPlaylistList"
                                             MaxHeight="320"
                                             SelectionMode="Single"
                                             ItemsSource="{Binding SidebarCollectedPlaylists}">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <localControls:SidebarPlaylistItemControl
                                                    OpenCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                    DeleteOnlinePlaylistCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteOnlinePlaylistCommand}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                        </StackPanel>
                        
                        <ToggleButton Name="AlbumPlaylistsHeader"
                                      Classes="SidebarSectionHeader"
                                      Content="收藏的专辑"
                                      IsChecked="{Binding IsAlbumPlaylistsExpanded, Mode=TwoWay}" />
                        <StackPanel IsVisible="{Binding IsAlbumPlaylistsExpanded}">
                                <ListBox Classes="SidebarPlaylistList"
                                         MaxHeight="320"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding SidebarAlbumPlaylists}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <localControls:SidebarPlaylistItemControl
                                                    OpenCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                    DeleteOnlinePlaylistCommand="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteOnlinePlaylistCommand}" />
                                            </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                        </StackPanel>
                        
                    </StackPanel>

                    <Button Height="36"
                            Classes="Basic"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuItem Header="导入其他平台歌单链接..."
                                          Command="{Binding PlaylistsViewModel.ImportExternalPlaylistCommand}" />
                                <MenuItem Header="新建歌单..."
                                          Command="{Binding PlaylistsViewModel.ShowCreatePlaylistDialogCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <Grid ColumnDefinitions="28,*" VerticalAlignment="Center">
                            <Border Grid.Column="0"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SukiPrimaryColorLow}" />
                            <Svg Grid.Column="0"
                                 Classes="ThemeSvgIcon"
                                 Path="/Assets/music-folder-8-svgrepo-com.svg"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="新建歌单"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource SukiLowText}" />
                        </Grid>
                    </Button>

                </StackPanel>
            </localControls:KugouSideMenu.FooterContent>
        </localControls:KugouSideMenu>

        <localControls:BottomPlaybackControl />
        <views:NowPlayingView DataContext="{Binding NowPlaying}"
                              ZIndex="300" />

    </Grid>
    </suki:SukiMainHost>
</localControls:KugouWindow>
