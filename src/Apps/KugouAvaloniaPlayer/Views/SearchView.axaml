<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:models="using:KuGou.Net.Abstractions.Models"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:models1="clr-namespace:KugouAvaloniaPlayer.Models"
             x:Class="KugouAvaloniaPlayer.Views.SearchView"
             x:Name="SearchRoot"
             x:DataType="vm:SearchViewModel"
             behaviors:InteractionBehaviors.AttachedToVisualTreeCommand="{Binding LoadSearchHotCommand}"
             behaviors:InteractionBehaviors.AttachedToVisualTreeCommandRunOnce="True">

    <UserControl.Styles>
        <Style Selector="ItemsRepeater.MainTagList ContentPresenter">
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style Selector="Button.HotTagChip">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>
    
    <suki:GlassCard Margin="15" Padding="25">
        <Grid RowDefinitions="Auto,*">
            
            <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*, Auto" MaxWidth="800" HorizontalAlignment="Stretch">
                <TextBox Grid.Column="0"
                         Text="{Binding SearchKeyword}"
                         Watermark="输入歌曲名、歌手名、歌单或专辑..."
                         CornerRadius="8"
                         Height="42"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                         behaviors:InteractionBehaviors.EnterKeyCommand="{Binding SearchCommand}">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                    <TextBox.InnerRightContent>
                        <Button Classes="Basic" 
                                Command="{Binding SearchCommand}"
                                IsEnabled="{Binding IsSearching, Converter={x:Static BoolConverters.Not}}"
                                Padding="12,0"
                                Cursor="Hand">
                            <PathIcon Data="{x:Static suki:Icons.Search}" Foreground="{DynamicResource SukiPrimaryColor}" />
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>
                
                <Button Grid.Column="1"
                        Classes="Basic"
                        Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding HasSearched}"
                        Padding="16,0"
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        ToolTip.Tip="清除搜索并返回">
                    <TextBlock Text="取消" FontSize="15" Foreground="{DynamicResource SukiLowText}" />
                </Button>
            </Grid>
            
            <Grid Grid.Row="1">
                
                <Grid IsVisible="{Binding !HasSearched}" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0"
                                IsVisible="{Binding IsLoadingHot}"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10"
                                Margin="0,40,0,0">
                        <suki:Loading Width="24" Height="24" />
                        <TextBlock Text="正在获取热搜榜..." Foreground="{DynamicResource SukiLowText}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" IsVisible="{Binding !IsLoadingHot}" Spacing="20" >
                        <TextBlock Text="大家都在搜"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SukiText}" />
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                            <ItemsRepeater Classes="MainTagList" ItemsSource="{Binding HotCategories}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate DataType="models1:SearchHotTagGroup">
                                        <RadioButton Classes="Segmented"
                                                     GroupName="SearchHotMainTags"
                                                     IsChecked="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).SelectedHotMainIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Index}}"
                                                     Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).SelectHotMainCategoryCommand}"
                                                     CommandParameter="{Binding Index}">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" Margin="5,0,0,0"/>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="-4,10,0,0"   
                                      Padding="4,4,0,0"> 
                            <ItemsControl ItemsSource="{Binding CurrentHotKeywords}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,5,0,0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models1:SearchHotTagItem">
                                        <Button Classes="Basic HotTagChip"
                                                Background="{DynamicResource SukiControlBackground}"
                                                BorderBrush="{DynamicResource SukiBorderBrush}"
                                                BorderThickness="1"
                                                Margin="0,0,12,12"
                                                Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).QuickSearchHotKeywordCommand}"
                                                CommandParameter="{Binding .}">
                                            <TextBlock Text="{Binding Keyword}" 
                                                       Foreground="{DynamicResource SukiText}" 
                                                       FontSize="14"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
                
                <Grid IsVisible="{Binding HasSearched}" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,15">
                        <RadioButton Content="单曲" Classes="Segmented"
                                     IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Song}}"
                                     Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Song" />
                        <RadioButton Content="歌单" Classes="Segmented"
                                     IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Playlist}}"
                                     Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Playlist" />
                        <RadioButton Content="专辑" Classes="Segmented"
                                     IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Album}}"
                                     Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Album" />
                    </StackPanel>

                    <!-- 列表与详情内容 -->
                    <Grid Grid.Row="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="10" IsVisible="{Binding IsSearching}">
                            <suki:Loading Width="24" Height="24" />
                            <TextBlock Text="正在检索中..." VerticalAlignment="Center" Foreground="{DynamicResource SukiLowText}" />
                        </StackPanel>

                        <!-- 单曲 -->
                        <ListBox Classes="SongList"
                                 ItemsSource="{Binding Songs}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="0,0,0,50"
                                 Background="Transparent">
                            <ListBox.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsSearching" />
                                    <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                             ConverterParameter="{x:Static models1:SearchType.Song}" />
                                    <Binding Path="!IsShowingDetail" />
                                </MultiBinding>
                            </ListBox.IsVisible>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:SongItem">
                                    <localControls:SongListItemControl />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 歌单 -->
                        <ScrollViewer Padding="0,0,0,50">
                            <ScrollViewer.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsSearching" />
                                    <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                             ConverterParameter="{x:Static models1:SearchType.Playlist}" />
                                    <Binding Path="!IsShowingDetail" />
                                </MultiBinding>
                            </ScrollViewer.IsVisible>
                            <ItemsRepeater ItemsSource="{Binding Playlists}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="184" MinItemHeight="236" MinColumnSpacing="15" MinRowSpacing="15" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate DataType="models:SearchPlaylistItem">
                                        <localControls:MediaCard Cover="{Binding Cover}"
                                                                 Title="{Binding Name}"
                                                                 Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                                 Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).OpenPlaylistCommand}"
                                                                 CommandParameter="{Binding .}" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <!-- 专辑 -->
                        <ScrollViewer Padding="0,0,0,50">
                            <ScrollViewer.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsSearching" />
                                    <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                             ConverterParameter="{x:Static models1:SearchType.Album}" />
                                    <Binding Path="!IsShowingDetail" />
                                </MultiBinding>
                            </ScrollViewer.IsVisible>
                            <ItemsRepeater ItemsSource="{Binding Albums}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MinItemWidth="184" MinItemHeight="236" MinColumnSpacing="15" MinRowSpacing="15" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate DataType="models:SearchAlbumItem">
                                        <localControls:MediaCard Cover="{Binding Cover}"
                                                                 Title="{Binding Name}"
                                                                 Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                                 Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).OpenAlbumCommand}"
                                                                 CommandParameter="{Binding .}" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <!-- 详情页 (专辑/歌单详情) -->
                        <localControls:SongCollectionDetailView
                            IsVisible="{Binding IsShowingDetail}"
                            Cover="{Binding DetailCover}"
                            Title="{Binding DetailTitle}"
                            Subtitle="{Binding DetailSubTitle}"
                            Songs="{Binding DetailSongs}"
                            LoadMoreCommand="{Binding LoadMoreDetailsCommand}"
                            BackCommand="{Binding GoBackCommand}"
                            IsLoadingMore="{Binding IsLoadingMoreDetails}"
                            LoadingMoreText="加载更多..."
                            ListPadding="0,0,0,50"
                            TitleFontSize="24"
                            HeroActionCommand="{Binding CollectPlaylistCommand}"
                            HeroActionIconData="{x:Static suki:Icons.Star}"
                            HeroActionIsVisible="{Binding CanCollectDetail}" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </suki:GlassCard>
</UserControl>