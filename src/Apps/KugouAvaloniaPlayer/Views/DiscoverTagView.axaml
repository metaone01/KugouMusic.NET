<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="KugouAvaloniaPlayer.Views.DiscoverTagView"
             x:Name="DiscoverTagRoot"
             x:DataType="vm:DiscoverTagViewModel">

    <UserControl.Styles>
        <Style Selector="ItemsRepeater.MainTagList ContentPresenter">
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style Selector="ItemsRepeater.MainTagList TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="ItemsRepeater.SubTagList ContentPresenter">
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style Selector="ItemsRepeater.SubTagList TextBlock">
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="15">
        <Grid IsVisible="{Binding !IsShowingSongs}" RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <Button Classes="Basic"
                        Command="{Binding NavigateBackCommand}"
                        Cursor="Hand"
                        ToolTip.Tip="返回发现">
                    <PathIcon Data="{x:Static suki:Icons.ChevronLeft}"
                              Foreground="{DynamicResource SukiLowText}" />
                </Button>
                <TextBlock Text="发现歌单"
                           FontSize="28"
                           FontWeight="ExtraBold"
                           VerticalAlignment="Center" />
                <Button Classes="Basic" Command="{Binding LoadTagsCommand}" Cursor="Hand">
                    <PathIcon Data="{x:Static suki:Icons.Refresh}" Foreground="{DynamicResource SukiLowText}" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="15" Margin="0,0,0,12">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsRepeater Classes="MainTagList"
                                   ItemsSource="{Binding Categories}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate DataType="vm:DiscoverPlaylistTagGroup">
                                <RadioButton Classes="Segmented"
                                             GroupName="DiscoverMainTags"
                                             IsChecked="{Binding #DiscoverTagRoot.((vm:DiscoverTagViewModel)DataContext).SelectedMainIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Index}}"
                                             Command="{Binding #DiscoverTagRoot.((vm:DiscoverTagViewModel)DataContext).SelectMainCategoryCommand}"
                                             CommandParameter="{Binding Index}">
                                    <TextBlock Text="{Binding TagName}" VerticalAlignment="Center" />
                                </RadioButton>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsRepeater Classes="SubTagList"
                                   ItemsSource="{Binding CurrentSubCategories}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate DataType="vm:DiscoverPlaylistTag">
                                <RadioButton Classes="Segmented"
                                             GroupName="DiscoverSubTags"
                                             IsChecked="{Binding #DiscoverTagRoot.((vm:DiscoverTagViewModel)DataContext).SelectedSubIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Index}}"
                                             Command="{Binding #DiscoverTagRoot.((vm:DiscoverTagViewModel)DataContext).SelectSubCategoryCommand}"
                                             CommandParameter="{Binding Index}">
                                    <TextBlock Text="{Binding TagName}" VerticalAlignment="Center" />
                                </RadioButton>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>

            <Grid Grid.Row="2">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            IsVisible="{Binding IsLoading}">
                    <suki:Loading Width="24" Height="24" />
                    <TextBlock Text="正在加载歌单..."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SukiLiquid2}" />
                </StackPanel>

                <ScrollViewer IsVisible="{Binding !IsLoading}" Padding="0,0,0,-50">
                    <ItemsRepeater ItemsSource="{Binding Playlists}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="184"
                                               MinItemHeight="236"
                                               MinColumnSpacing="0"
                                               MinRowSpacing="0" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate DataType="vm:DiscoverPlaylist">
                                <localControls:MediaCard Cover="{Binding Cover}"
                                                         Title="{Binding Name}"
                                                         Subtitle="{Binding PlayCountText}"
                                                         Command="{Binding #DiscoverTagRoot.((vm:DiscoverTagViewModel)DataContext).OpenPlaylistCommand}"
                                                         CommandParameter="{Binding .}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Grid>

        <localControls:SongCollectionDetailView
            IsVisible="{Binding IsShowingSongs}"
            Cover="{Binding SelectedPlaylist.Cover}"
            Title="{Binding SelectedPlaylist.Name}"
            Subtitle="{Binding SelectedPlaylist.CreatorName, StringFormat='by {0}'}"
            Songs="{Binding SelectedPlaylistSongs}"
            LoadMoreCommand="{Binding LoadMoreSongsCommand}"
            BackCommand="{Binding GoBackCommand}"
            IsLoadingMore="{Binding IsLoadingMoreSongs}"
            ShowAddLoadedSongsToQueueButton="True"
            HeroActionCommand="{Binding CollectPlaylistCommand}"
            HeroActionIconData="{x:Static suki:Icons.Star}" />
    </Grid>
</UserControl>
