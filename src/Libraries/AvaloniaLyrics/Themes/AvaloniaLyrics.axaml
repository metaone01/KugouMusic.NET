<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lyrics="clr-namespace:AvaloniaLyrics;assembly=AvaloniaLyrics">

    <Style Selector="lyrics|LyricView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Preset" Value="Default" />
        <Setter Property="ActiveAnchorRatio" Value="0.5" />
        <Setter Property="EnableAnimation" Value="False" />
        <Setter Property="EnableStagger" Value="False" />
        <Setter Property="EnableScale" Value="False" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter>
                        <ItemsPresenter.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsPresenter.ItemsPanel>
                    </ItemsPresenter>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
